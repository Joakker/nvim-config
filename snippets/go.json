{
  "Interface type": {
    "prefix": ["tyi"],
    "body": ["type ${1:Name} interface {", "\t$0", "}"]
  },
  "Struct type": {
    "prefix": ["tys"],
    "body": ["type ${1:Name} struct {", "\t$0", "}"]
  },
  "Type New": {
    "prefix": ["tynew"],
    "body": [
      "type ${1:Name} struct {",
      "\t$3",
      "}",
      "",
      "func New${2:$1}($4) *$1 {",
      "\treturn &$1{}",
      "}"
    ],
    "description": "Struct with constructor"
  },
  "Method": {
    "prefix": ["meth"],
    "body": ["func ($1) ${2:name}($3) $4 {", "\t$0", "}"],
    "description": "Method definition"
  },
  "Function": {
    "prefix": ["func"],
    "body": ["func ${1:name}($2) $3 {", "\t$0", "}"],
    "description": "Function definition"
  },
  "If condition": {
    "prefix": ["if"],
    "body": ["if ${1:true} {", "\t$0", "}"],
    "description": "If condition"
  },
  "For loop": {
    "prefix": ["for", "forr"],
    "body": ["for ${1:i, v} := range ${2:[]int{}) {", "\t$0", "}"],
    "description": "For range loop"
  },
  "Switch case": {
    "prefix": ["switch"],
    "body": ["switch ${1:name} {", "case ${2:pattern}:", "\t$0", "}"]
  },
  "Main function": {
    "prefix": ["main"],
    "body": ["func main() {", "\t$0", "}"],
    "description": "Main function"
  },
  "Init function": {
    "prefix": ["init"],
    "body": ["func init() {", "\t$0", "}"],
    "description": "Init function"
  }
}
