snippet func "function definition" b
${1:void} ${2:name}($3) {
	$0
}
endsnippet

snippet main "main function" b
int main(int argc, char* argv[]) {
	$0
	return 0;
}
endsnippet

snippet for "for loop" b
for (${2:int ${1:i} = 0}; ${3: $1 < 10}; ${4:$1++}) {
	$0
}
endsnippet

snippet forever "forever" b
for (;;) {
	$0
}
endsnippet
