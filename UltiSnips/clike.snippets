snippet func "Function definition"
${1:void} ${2:name}($3) {
	$0
}
endsnippet

snippet main "Main function"
int main(int argc, char* argv[]) {
	$0
	return 0;
}
endsnippet

snippet for "For loop"
for (${2:int ${1:i} = 0}; ${3: $1 < 10}; ${4:$1++}) {
	$0
}
endsnippet

snippet forever "Forever"
for (;;) {
	$0
}
endsnippet
