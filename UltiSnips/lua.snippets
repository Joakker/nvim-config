snippet fori "for i" b
for ${1:i} = ${2:1}, ${3:10} do
	$0
end
endsnippet

snippet forp "for k, v" b
for ${1:k}, ${2:v} in ${3:pairs(table)} do
	$0
end
endsnippet

snippet if "if ..." b
if ${1:condition} then
	$0
end
endsnippet

snippet func "function definition" b
function $1($2)
	$0
end
endsnippet

snippet module "module boilerplate" b
local ${1:M} = {}

$0

return $1
endsnippet
