priority -50

snippet func "function definition" b
function ${1:name}($2) {
	$0
}
endsnippet

snippet fori "for i..." b
for (let ${1:i} = ${2:0}; ${4:$1 < $3}; ${5:$1++}) {
	$0
}
endsnippet

snippet forn "for e in..." b
for (const ${1:e} in ${2:object} ) {
	$0
}
endsnippet

snippet foro "for of..." b
for (const ${1:e} of ${2:array}) {
	$0
}
endsnippet

snippet class "class definition" b
class ${1:Person} {
	$0
}
endsnippet
